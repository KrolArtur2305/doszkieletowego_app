{
  "expo": {
    "name": "BuildIQ",
    "slug": "buildiq",
    "scheme": "buildiq",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo-square.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "icon": "./assets/logo-square.png",
      "buildNumber": "17",
      "bundleIdentifier": "pl.buildiq.mobile",
      "splash": {
        "image": "./assets/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "BuildIQ needs photo library access so you can add construction photos and project images.",
        "NSCameraUsageDescription": "BuildIQ needs camera access so you can scan invoices and receipts.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 5,
      "package": "com.buildiq.app",
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-square.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#25F0C8",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-localization",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#000000",
          "barStyle": "light"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5618053-5986-4a05-a501-ac03285394b2"
      }
    },
    "owner": "krolartur23"
  }
}
