{
  "expo": {
    "name": "BuildIQ",
    "slug": "buildiq",
    "scheme": "buildiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-square.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./app/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "icon": "./assets/logo-square.png",
      "buildNumber": "13",
      "bundleIdentifier": "pl.buildiq.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "BuildIQ needs photo library access so you can add construction photos and project images.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.buildiq.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-square.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./app/assets/icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5618053-5986-4a05-a501-ac03285394b2"
      }
    },
    "owner": "krolartur23"
  }
}
